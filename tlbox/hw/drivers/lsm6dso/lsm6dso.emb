  FUNC_CFG_ACCESS      = 0x01

struct FuncCfgAccess:
  -- FUNC_CFG_ACCESS

  # XXX: Probably am defining backwards
  0 [+1] bits:
    0 [+1] Flag func_cfg_access
      -- ?

    1 [+1] Flag shub_reg_access
      -- ?

    2 [+6] UInt reserved
      [requires: this == 0x00]
